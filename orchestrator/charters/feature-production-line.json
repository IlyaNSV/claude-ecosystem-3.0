{
  "id": "feature-production-line",
  "version": 6,
  "context": { "feature": null, "fm": null },
  "initial": "handoff_ready",
  "limits": { "lane": "orchestrator", "wip": 1 },
  "states": {
    "handoff_ready": {
      "meta": { "determinism": "H", "autonomy": "human-gate" },
      "on": {
        "evt:line.start": { "target": "authoring", "guard": "wip_ok" }
      }
    },
    "authoring": {
      "invoke": { "process": "batch-features-to-cc-sdd" },
      "meta": { "determinism": "DL3", "autonomy": "auto" },
      "on": {
        "evt:spec.authored": { "target": "fidelity_audit" },
        "evt:spec.blocked": { "target": "escalated", "actions": ["queue_owner"] }
      }
    },
    "fidelity_audit": {
      "invoke": { "process": "audit-spec-fidelity" },
      "meta": { "determinism": "DL2", "autonomy": "auto" },
      "on": {
        "evt:fidelity.impl_ready": { "target": "implementing" },
        "evt:fidelity.product_routed": { "target": "awaiting_product", "actions": ["queue_owner"] },
        "evt:fidelity.residual": { "target": "escalated", "actions": ["queue_owner"] }
      }
    },
    "implementing": {
      "invoke": { "process": "feature-to-tdd-impl" },
      "meta": { "determinism": "DL2", "autonomy": "auto" },
      "on": {
        "evt:impl.go": { "target": "runtime_gate" },
        "evt:impl.no_go": [
          { "target": "remediation", "guard": "rounds_left" },
          { "target": "escalated", "actions": ["queue_owner"] }
        ],
        "evt:impl.conflict": { "target": "awaiting_product", "actions": ["queue_owner"] },
        "evt:impl.blocked_capability": { "target": "awaiting_capability_impl", "actions": ["queue_owner"] },
        "evt:impl.manual_verify": { "target": "escalated", "actions": ["queue_owner"] }
      }
    },
    "remediation": {
      "invoke": { "process": "validate-feature-impl" },
      "meta": { "determinism": "DL2", "autonomy": "auto", "counter": "remediation_rounds", "max": 2 },
      "on": {
        "evt:impl.go": { "target": "runtime_gate" },
        "evt:impl.no_go": [
          { "target": "remediation", "guard": "rounds_left" },
          { "target": "escalated", "actions": ["queue_owner"] }
        ],
        "evt:impl.conflict": { "target": "awaiting_product", "actions": ["queue_owner"] },
        "evt:impl.manual_verify": { "target": "escalated", "actions": ["queue_owner"] }
      }
    },
    "runtime_gate": {
      "invoke": { "process": "runtime-smoke-readiness" },
      "meta": { "determinism": "DL0", "autonomy": "auto" },
      "on": {
        "evt:runtime.ready_or_started": { "target": "deploying_staging" },
        "evt:runtime.blocked_capability": { "target": "awaiting_capability", "actions": ["queue_owner"] },
        "evt:runtime.env_not_ready": { "target": "runtime_gate_retry" },
        "evt:fidelity.product_routed": { "target": "awaiting_product", "actions": ["queue_owner"] }
      }
    },
    "deploying_staging": {
      "invoke": { "process": "deploy-to-stage" },
      "meta": { "determinism": "DL0", "operation_class": "deploy_staging", "env_tier": "staging", "risk": "HIGH" },
      "on": {
        "evt:owner.close": { "target": "closed_without_runtime" },
        "evt:deploy.succeeded": { "target": "journey_acceptance" },
        "evt:deploy.failed": { "target": "rolling_back" },
        "evt:deploy.preflight_failed": { "target": "escalated", "actions": ["queue_owner"] },
        "evt:deploy.env_not_ready": { "target": "runtime_gate_retry" },
        "evt:deploy.gated": { "target": "runtime_gate_retry" }
      }
    },
    "journey_acceptance": {
      "invoke": { "process": "user-journey-acceptance" },
      "meta": { "determinism": "DL0", "autonomy": "auto" },
      "on": {
        "evt:owner.close": { "target": "closed_without_runtime" },
        "evt:journey.passed": { "target": "done" },
        "evt:journey.failed": { "target": "awaiting_journey_fix", "actions": ["queue_owner"] },
        "evt:journey.env_not_ready": { "target": "runtime_gate_retry" }
      }
    },
    "rolling_back": {
      "invoke": { "process": "rollback-release" },
      "meta": { "determinism": "DL0", "operation_class": "rollback", "env_tier": "staging", "risk": "HIGH" },
      "on": {
        "evt:rollback.done": { "target": "rolled_back", "actions": ["queue_owner"] },
        "evt:rollback.no_prior": { "target": "escalated", "actions": ["queue_owner"] },
        "evt:rollback.failed": { "target": "escalated", "actions": ["queue_owner"] }
      }
    },
    "rolled_back": {
      "meta": { "autonomy": "human-gate", "queue_kind": "gate" },
      "on": {
        "evt:owner.resume": { "target": "implementing" },
        "evt:owner.close": { "target": "closed_without_runtime" }
      }
    },
    "runtime_gate_retry": {
      "meta": { "determinism": "H", "autonomy": "human-gate", "queue_kind": "gate" },
      "on": {
        "evt:env.up": { "target": "runtime_gate" },
        "evt:owner.close": { "target": "closed_without_runtime" }
      }
    },
    "awaiting_journey_fix": {
      "meta": { "autonomy": "human-gate", "queue_kind": "gate" },
      "on": {
        "evt:owner.resume": { "target": "implementing" },
        "evt:owner.close": { "target": "closed_without_runtime" }
      }
    },
    "awaiting_product": {
      "meta": { "autonomy": "human-gate", "queue_kind": "conflict" },
      "on": {
        "evt:pa.resolved": { "target": "implementing" },
        "evt:owner.close": { "target": "closed_without_runtime" }
      }
    },
    "awaiting_capability": {
      "meta": { "autonomy": "human-gate", "queue_kind": "conflict" },
      "on": {
        "evt:pa.resolved": { "target": "runtime_gate" },
        "evt:owner.close": { "target": "closed_without_runtime" }
      }
    },
    "awaiting_capability_impl": {
      "meta": { "autonomy": "human-gate", "queue_kind": "conflict" },
      "on": {
        "evt:pa.resolved": { "target": "implementing" },
        "evt:owner.close": { "target": "closed_without_runtime" }
      }
    },
    "escalated": {
      "meta": { "autonomy": "human-gate", "queue_kind": "gate" },
      "on": {
        "evt:owner.resume": { "target": "implementing" },
        "evt:owner.abort": { "target": "aborted" },
        "evt:owner.close": { "target": "closed_without_runtime" }
      }
    },
    "done": { "final": true, "actions": ["project_fm_shipped_hint"] },
    "aborted": { "final": true },
    "closed_without_runtime": { "final": true }
  },
  "guards": {
    "wip_ok": { "kind": "builtin", "ref": "wipOk" },
    "rounds_left": { "kind": "builtin", "ref": "counterBelowMax" }
  },
  "ingest": {
    "batch-features-to-cc-sdd": [
      { "when": { "path": "blocked", "nonEmpty": true }, "emit": "evt:spec.blocked" },
      { "default": true, "emit": "evt:spec.authored" }
    ],
    "audit-spec-fidelity": [
      { "when": { "path": "product_routed", "nonEmpty": true }, "emit": "evt:fidelity.product_routed" },
      { "when": { "path": "residual", "nonEmpty": true }, "emit": "evt:fidelity.residual" },
      { "when": { "path": "impl_ready", "nonEmpty": true }, "emit": "evt:fidelity.impl_ready" }
    ],
    "feature-to-tdd-impl": [
      { "when": { "path": "conflicts", "nonEmpty": true }, "emit": "evt:impl.conflict" },
      { "when": { "path": "capability_blocked", "nonEmpty": true }, "emit": "evt:impl.blocked_capability", "payloadPath": "capability_blocked" },
      { "when": { "path": "go_gate", "eq": "GO" }, "emit": "evt:impl.go" },
      { "when": { "path": "go_gate", "eq": "NO-GO" }, "emit": "evt:impl.no_go" },
      { "when": { "path": "go_gate", "eq": "MANUAL_VERIFY_REQUIRED" }, "emit": "evt:impl.manual_verify" },
      { "when": { "path": "blocked", "nonEmpty": true }, "emit": "evt:impl.manual_verify" }
    ],
    "validate-feature-impl": [
      { "when": { "path": "conflicts", "nonEmpty": true }, "emit": "evt:impl.conflict" },
      { "when": { "path": "result", "eq": "GO" }, "emit": "evt:impl.go" },
      { "when": { "path": "result", "eq": "NO-GO" }, "emit": "evt:impl.no_go" },
      { "when": { "path": "result", "eq": "MANUAL_VERIFY_REQUIRED" }, "emit": "evt:impl.manual_verify" }
    ],
    "runtime-smoke-readiness": [
      { "when": { "path": "verdict", "eq": "BLOCKED_ON_CAPABILITY" }, "emit": "evt:runtime.blocked_capability", "payloadPath": "requests" },
      { "when": { "path": "verdict", "eq": "ENV_NOT_READY" }, "emit": "evt:runtime.env_not_ready" },
      { "when": { "path": "verdict", "in": ["READY_TO_SMOKE"] }, "emit": "evt:runtime.ready_or_started" },
      { "when": { "path": "verdict", "eq": "NOT_STARTABLE" }, "emit": "evt:fidelity.product_routed" }
    ],
    "deploy-to-stage": [
      { "when": { "path": "readiness", "eq": "ENV_NOT_READY" }, "emit": "evt:deploy.env_not_ready" },
      { "when": { "path": "result", "eq": "BLOCKED" }, "emit": "evt:deploy.gated", "payloadPath": "autonomy" },
      { "when": { "path": "result", "eq": "DEPLOYED" }, "emit": "evt:deploy.succeeded" },
      { "when": { "path": "flipped", "eq": true }, "emit": "evt:deploy.failed" },
      { "default": true, "emit": "evt:deploy.preflight_failed" }
    ],
    "user-journey-acceptance": [
      { "when": { "path": "uja_result", "eq": "ENV_NOT_READY" }, "emit": "evt:journey.env_not_ready" },
      { "when": { "path": "uja_result", "eq": "PASS" }, "emit": "evt:journey.passed" },
      { "when": { "path": "uja_result", "eq": "FAIL" }, "emit": "evt:journey.failed" }
    ],
    "rollback-release": [
      { "when": { "path": "result", "eq": "ROLLED_BACK" }, "emit": "evt:rollback.done" },
      { "when": { "path": "result", "eq": "NO_PRIOR_RELEASE" }, "emit": "evt:rollback.no_prior" },
      { "default": true, "emit": "evt:rollback.failed" }
    ]
  }
}
