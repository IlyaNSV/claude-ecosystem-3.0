# Ecosystem 3.0 — Environment Variables
#
# Copy to .env and fill in your API keys.
# .env is gitignored — never commit it.

# ============================================================
# Core MCP API Keys (required for Discovery Deep mode)
# ============================================================

# Brave Search — https://api.search.brave.com/
# Used: research keyword lookups, debug error patterns
# Free tier: 2000 queries/month
BRAVE_API_KEY=

# Firecrawl — https://www.firecrawl.dev/
# Used: web scraping in MR/CA Deep mode
# Free tier: 500 pages/month
FIRECRAWL_API_KEY=

# Exa AI — https://exa.ai/
# Used: semantic search in research/debug
EXA_API_KEY=

# ============================================================
# Optional Keys
# ============================================================

# GitHub Personal Access Token — https://github.com/settings/tokens
# Used: GitHub MCP (CA Deep for dev tools, NFR benchmarks)
# Scopes: public_repo, read:org
GITHUB_TOKEN=

# Stitch Project URL — https://stitch.withgoogle.com/
# Required only if first feature has has_ui=true
STITCH_PROJECT_URL=

# ============================================================
# Default Configuration
# ============================================================

# Validation tier — affects which V-* rules run inline (B1 modification)
# Values: pilot | mvp | full
ECOSYSTEM_DEFAULT_TIER=pilot

# Discovery mode default
# Values: quick | deep
ECOSYSTEM_DEFAULT_DISCOVERY_MODE=quick

# Project language (used for Product Module dialogue)
ECOSYSTEM_PROJECT_LANGUAGE=ru
